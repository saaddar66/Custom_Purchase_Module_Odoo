<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_purchase" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.purchase.custom</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="25"/>
        <field name="inherit_id" ref="purchase.res_config_settings_view_form_purchase"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='purchase']" position="inside">
                <block title="Purchase Automation &amp; Logic" id="purchase_automation_setting_container">
                    <setting string="Approval Limit" help="Orders above this amount will require approval">
                        <field name="approval_limit"/>
                    </setting>
                    <setting string="Default Expense Account" help="Default account to use for expenses on purchase orders.">
                        <field name="default_expense_account_id"/>
                    </setting>
                    <setting string="Auto RFQ" help="Automatically generate RFQs based on stock logic.">
                        <field name="auto_rfq"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
