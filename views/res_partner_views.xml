<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_inherit_purchase_custom" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.purchase.custom</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='sales_purchases']//group[@name='purchase']" position="inside">
                <group string="Purchase Properties" name="purchase_properties">
                    <field name="vendor_rating" widget="priority"/>
                    <field name="is_preferred_vendor"/>
                    <field name="payment_term_override"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
