<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Nightly Cron for Pending Approvals -->
        <record id="ir_cron_purchase_pending_reminder" model="ir.cron">
            <field name="name">Purchase: Pending Approval Reminder</field>
            <field name="model_id" ref="purchase.model_purchase_order"/>
            <field name="state">code</field>
            <field name="code">model._cron_reminder_pending_approval()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
            <field name="nextcall" eval="(datetime.now() + timedelta(days=1)).strftime('%Y-%m-%d 02:00:00')"/>
        </record>
    </data>
</odoo>
